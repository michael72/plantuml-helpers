{
  "name": "plantuml-helpers",
  "displayName": "PlantUmlHelpers",
  "description": "Editor extension that helps facilitate editing and creation of PlantUML diagrams",
  "version": "0.9.1",
  "publisher": "michael72",
  "type": "module",
  "engines": {
    "vscode": "^1.110.0"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "bugs": {
    "url": "https://github.com/michael72/plantuml-helpers/issues"
  },
  "homepage": "https://github.com/michael72/plantuml-helpers/blob/master/README.md",
  "repository": {
    "type": "git",
    "url": "https://github.com/michael72/plantuml-helpers.git"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Snippets",
    "Other"
  ],
  "main": "./out/src/extension.js",
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:plantuml"
  ],
  "contributes": {
    "markdown.markdownItPlugins": true,
    "commands": [
      {
        "command": "pumlhelper.swapLine",
        "title": "Swap arrow and content",
        "category": "PlantUMLHelpers"
      },
      {
        "command": "pumlhelper.rotateLineLeft",
        "title": "Rotate arrow left",
        "category": "PlantUMLHelpers"
      },
      {
        "command": "pumlhelper.rotateLineRight",
        "title": "Rotate arrow right",
        "category": "PlantUMLHelpers"
      },
      {
        "command": "pumlhelper.autoFormat",
        "title": "Auto Format (fix arrow layout)",
        "category": "PlantUMLHelpers"
      },
      {
        "command": "pumlhelper.reFormat",
        "title": "Reset Arrow Directions to Defaults",
        "category": "PlantUMLHelpers"
      },
      {
        "command": "pumlhelper.showPreview",
        "title": "Show PlantUML Preview",
        "category": "PlantUMLHelpers"
      },
      {
        "command": "pumlhelper.setTheme",
        "title": "Set theme",
        "category": "PlantUMLHelpers"
      },
      {
        "command": "pumlhelper.installPumlsrv",
        "title": "Install pumlsrv",
        "category": "PlantUMLHelpers"
      }
    ],
    "keybindings": [
      {
        "command": "pumlhelper.rotateLineLeft",
        "key": "Alt+8"
      },
      {
        "command": "pumlhelper.swapLine",
        "key": "Alt+9"
      },
      {
        "command": "pumlhelper.rotateLineRight",
        "key": "Alt+0"
      },
      {
        "command": "pumlhelper.showPreview",
        "key": "Alt+P"
      }
    ],
    "configuration": {
      "title": "PlantUML Helpers",
      "properties": {
        "plantumlHelpers.serverType": {
          "type": "string",
          "enum": [
            "PlantUML Server",
            "Local pumlsrv",
            "Other"
          ],
          "enumDescriptions": [
            "Use the public PlantUML server at plantuml.com",
            "Use a local pumlsrv instance (lightweight local server). The first render will prompt to install it if not present.",
            "Use a custom PlantUML server URL"
          ],
          "default": "PlantUML Server",
          "markdownDescription": "Which PlantUML server to use for rendering diagrams. When _Local pumlsrv_ is selected the extension manages a local [pumlsrv](https://github.com/michael72/pumlsrv) process. [$(cloud-download) Install pumlsrv](command:pumlhelper.installPumlsrv)"
        },
        "plantumlHelpers.pumlsrvPort": {
          "type": "number",
          "default": 8380,
          "description": "Port for the local pumlsrv server. Only used when serverType is 'Local pumlsrv'."
        },
        "plantumlHelpers.serverUrl": {
          "type": "string",
          "default": "http://localhost:8080/plantuml",
          "description": "Custom PlantUML server URL. Only used when serverType is 'Other'."
        },
        "plantumlHelpers.renderMethod": {
          "type": "string",
          "enum": [
            "get",
            "post",
            "post-deflate"
          ],
          "default": "get",
          "description": "Method to communicate with the PlantUML server. 'get' encodes the diagram in the URL (default), 'post' sends the diagram as plain text in the request body, 'post-deflate' sends a deflate-compressed diagram in the request body."
        },
        "plantumlHelpers.theme": {
          "type": "string",
          "default": "_none_",
          "description": "PlantUML theme used for rendering diagrams. Use the 'Set theme' command to pick from available themes."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "lint": "eslint src test --ext ts",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "vsix": "npx @vscode/vsce package",
    "vsix-ls": "npx @vscode/vsce ls",
    "clean": "rm -Rf node_modules out package-lock.json && npm install"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "@vscode/vsce": "^3.7.1",
    "eslint": "^10.0.3",
    "markdown-it": "^14.1.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "4.1.0"
  }
}
